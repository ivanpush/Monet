{
  "permissions": {
    "allow": [
      "Bash(./scripts/verify-reconnect.py:*)",
      "Bash(~/.monet/bin/monet-title:*)",
      "Bash(npm run compile:*)",
      "Bash(chmod:*)",
      "Bash(python3:*)",
      "WebSearch",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(cat:*)",
      "Bash(npm run package:*)",
      "Bash(cursor --install-extension:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.monet/bin/monet-status 35b3f558 thinking __monet__",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.monet/bin/monet-status 35b3f558 active __monet__",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.monet/bin/monet-status 35b3f558 waiting __monet__",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.monet/bin/monet-status 35b3f558 idle __monet__",
            "async": true,
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.monet/bin/monet-title-check 35b3f558 __monet__",
            "async": true,
            "timeout": 20
          }
        ]
      }
    ]
  }
}